# Environment
NODE_ENV=production

# Server
# Render sets PORT automatically — do not hardcode in production
PORT=3000

# Database (Neon)
# Use the pooled connection string from Neon dashboard
# Include ?sslmode=verify-full at the end
DATABASE_URL=postgresql://user:password@host.neon.tech/dbname?sslmode=verify-full

# Only needed for local dev (not used when DATABASE_URL is set)
DB_HOST=127.0.0.1
DB_PORT=5433
DB_NAME=laptheworld
DB_USER=
DB_PASSWORD=

# CORS
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=https://laptheworld.vercel.app,http://localhost:5173

# URLs (used in email links)
FRONTEND_URL=https://laptheworld.vercel.app
BACKEND_URL=https://your-service.onrender.com

# JWT
JWT_SECRET=
JWT_EXPIRES_IN=7d

# Auth
SALT_ROUNDS=12
MAX_FAILED_ATTEMPTS=5
LOCK_DURATION_MS=900000

# Google OAuth (social login)
GOOGLE_CLIENT_ID=

# Gmail (transactional email via OAuth2)
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_SENDER_EMAIL=
# ADMIN_EMAIL defaults to GMAIL_SENDER_EMAIL if not set
ADMIN_EMAIL=

# Groq AI
GROQ_API_KEY=

# Supabase Storage (file uploads)
# Project URL from Supabase dashboard → Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
# Secret key (sb_secret_... or service_role key) from Supabase → Settings → API
SUPABASE_SERVICE_ROLE_KEY=
# Name of the storage bucket you created (e.g. "media")
SUPABASE_BUCKET=blogUploads
